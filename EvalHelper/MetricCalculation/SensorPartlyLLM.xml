  <endpoints>
    <user>https-post://cpee.org/services/timeout-user.php</user>
    <auto>https-post://cpee.org/services/timeout-auto.php</auto>
    <subprocess>https-post://cpee.org/flow/start/url/</subprocess>
    <timeout>https-post://cpee.org/services/timeout.php</timeout>
    <send>https-post://cpee.org/ing/correlators/message/send/</send>
    <receive>https-get://cpee.org/ing/correlators/message/receive/</receive>
    <sensors>https://power.bpm.cit.tum.de/simulator/readsensor</sensors>
    <changelumens>https://power.bpm.cit.tum.de/simulator/changelumens</changelumens>
    <llm_call>https://power.bpm.cit.tum.de/llm/llm_call</llm_call>
  </endpoints>
  <attributes>
    <guarded>none</guarded>
    <info>SensorPartlyLLM</info>
    <modeltype>CPEE</modeltype>
    <theme>extended</theme>
    <guarded_id/>
    <creator>Christine Ashcreek</creator>
    <author>Christine Ashcreek</author>
    <model_uuid>5013e6fe-adaa-4800-aa5c-b5861fbd2b8c</model_uuid>
    <model_version/>
    <design_stage>development</design_stage>
    <design_dir>Staff.dir/Loebbi.dir/AgenticFundamentals.dir</design_dir>
  </attributes>
  <description>
    <description xmlns="http://cpee.org/ns/description/1.0">
      <loop eid="e1" mode="pre_test" condition="true">
        <_probability>
          <_probability_min/>
          <_probability_max/>
          <_probability_avg/>
        </_probability>
        <_annotations>
          <_generic/>
          <_logging_behavior>
            <_iteration>false</_iteration>
          </_logging_behavior>
        </_annotations>
        <call id="a1" endpoint="sensors">
          <parameters>
            <label>GetSensor</label>
            <color/>
            <method>:get</method>
            <arguments/>
          </parameters>
          <code>
            <signal>false</signal>
            <prepare/>
            <finalize output="result">data.sensor_payload = result.to_json()
data.occupancy = result["occupancy_count"]
data.time = result["dataset_timestamp"].split("T").last
data.current = result["current_light_lumen"]
data.ambient = result["ambient_light_lux"]
data.motion = result["motion_detected"]
data.input = result["user_input"]</finalize>
            <update output="result"/>
            <rescue output="result"/>
          </code>
          <annotations>
            <_generic/>
            <_logging_behavior>
              <_exclude>false</_exclude>
              <_include>false</_include>
            </_logging_behavior>
            <_timing>
              <_timing_weight/>
              <_timing_avg/>
              <explanations/>
            </_timing>
            <_shifting>
              <_shifting_type>Duration</_shifting_type>
            </_shifting>
            <_context_data_analysis>
              <probes/>
              <ips/>
            </_context_data_analysis>
            <report>
              <url/>
            </report>
            <_notes>
              <_notes_general/>
            </_notes>
          </annotations>
          <documentation>
            <input/>
            <output/>
            <implementation>
              <description/>
            </implementation>
            <code>
              <description/>
            </code>
          </documentation>
        </call>
        <choose eid="e2" mode="exclusive" label="occupancy comparison">
          <alternative eid="e15" condition="!data.input.to_s.strip.empty?">
            <_probability>
              <_probability_min/>
              <_probability_max/>
              <_probability_avg/>
            </_probability>
            <call id="a5" endpoint="llm_call">
              <parameters>
                <label>llm_call</label>
                <color/>
                <method>:post</method>
                <arguments>
                  <prompt>data.input</prompt>
                  <model>google/gemma-4-31B-it</model>
                </arguments>
              </parameters>
              <code>
                <signal>false</signal>
                <prepare/>
                <finalize output="result"/>
                <update output="result"/>
                <rescue output="result"/>
              </code>
              <annotations>
                <_generic/>
                <_logging_behavior>
                  <_exclude>false</_exclude>
                  <_include>false</_include>
                </_logging_behavior>
                <_timing>
                  <_timing_weight/>
                  <_timing_avg/>
                  <explanations/>
                </_timing>
                <_shifting>
                  <_shifting_type>Duration</_shifting_type>
                </_shifting>
                <_context_data_analysis>
                  <probes/>
                  <ips/>
                </_context_data_analysis>
                <report>
                  <url/>
                </report>
                <_notes>
                  <_notes_general/>
                </_notes>
              </annotations>
              <documentation>
                <input/>
                <output/>
                <implementation>
                  <description/>
                </implementation>
                <code>
                  <description/>
                </code>
              </documentation>
            </call>
          </alternative>
          <alternative eid="e4" condition="data.occupancy &lt; 1  and data.current== 0">
            <_probability>
              <_probability_min/>
              <_probability_max/>
              <_probability_avg/>
            </_probability>
          </alternative>
          <alternative eid="e3" condition="data.occupancy &lt; 1  and data.current != 0">
            <_probability>
              <_probability_min/>
              <_probability_max/>
              <_probability_avg/>
            </_probability>
            <call id="a2" endpoint="changelumens">
              <parameters>
                <label>Set lumen to 0</label>
                <color/>
                <method>:put</method>
                <arguments>
                  <lumen>0</lumen>
                </arguments>
              </parameters>
              <code>
                <signal>false</signal>
                <prepare/>
                <finalize output="result"/>
                <update output="result"/>
                <rescue output="result"/>
              </code>
              <annotations>
                <_generic/>
                <_logging_behavior>
                  <_exclude>false</_exclude>
                  <_include>false</_include>
                </_logging_behavior>
                <_timing>
                  <_timing_weight/>
                  <_timing_avg/>
                  <explanations/>
                </_timing>
                <_shifting>
                  <_shifting_type>Duration</_shifting_type>
                </_shifting>
                <_context_data_analysis>
                  <probes/>
                  <ips/>
                </_context_data_analysis>
                <report>
                  <url/>
                </report>
                <_notes>
                  <_notes_general/>
                </_notes>
              </annotations>
              <documentation>
                <input/>
                <output/>
                <implementation>
                  <description/>
                </implementation>
                <code>
                  <description/>
                </code>
              </documentation>
            </call>
          </alternative>
          <otherwise>
            <manipulate id="a3" label="Prepare Prompt">
              <code>hour = data.time.split(":").first.to_i

data.time =
  if hour &gt;= 23 || hour &lt; 6
    "night"
  elsif hour &lt; 9
    "morning"
  elsif hour &lt; 14
    "midday"
  elsif hour &lt; 18
    "afternoon"
  else
    "evening"
  end

data.llm_input = "Do not request from the sensors again. It is currently #{data.time}, the lamp is currently at #{data.current} and the current lux is at #{data.ambient}. Do not change the lumen of the lamp unless any of the following rules hold: (1) If it is morning aim for 100-200 lux, (2) If it is midday aim for 300-500 lux, (3) If it is afternoon aim for 200-300 lux, and (4) If it is evening aim for 200-300 lux! Use the logging tool! Use the following lumen to lux formula: lumen*7.5761. Only send rounded to integer lumen."</code>
              <annotations>
                <_logging_behavior>
                  <_exclude>false</_exclude>
                </_logging_behavior>
                <_context_data_analysis>
                  <probes/>
                </_context_data_analysis>
              </annotations>
            </manipulate>
            <call id="a6" endpoint="llm_call">
              <parameters>
                <label>llm_call</label>
                <color/>
                <method>:post</method>
                <arguments>
                  <prompt>!data.llm_input</prompt>
                  <model>google/gemma-4-31B-it</model>
                </arguments>
              </parameters>
              <code>
                <signal>false</signal>
                <prepare/>
                <finalize output="result">data.llm_answer = result</finalize>
                <update output="result"/>
                <rescue output="result"/>
              </code>
              <annotations>
                <_generic/>
                <_logging_behavior>
                  <_exclude>false</_exclude>
                  <_include>false</_include>
                </_logging_behavior>
                <_timing>
                  <_timing_weight/>
                  <_timing_avg/>
                  <explanations/>
                </_timing>
                <_shifting>
                  <_shifting_type>Duration</_shifting_type>
                </_shifting>
                <_context_data_analysis>
                  <probes/>
                  <ips/>
                </_context_data_analysis>
                <report>
                  <url/>
                </report>
                <_notes>
                  <_notes_general/>
                </_notes>
              </annotations>
              <documentation>
                <input/>
                <output/>
                <implementation>
                  <description/>
                </implementation>
                <code>
                  <description/>
                </code>
              </documentation>
            </call>
          </otherwise>
        </choose>
        <call id="a4" endpoint="timeout">
          <parameters>
            <label>wait for next iteration</label>
            <color/>
            <arguments>
              <timeout>1</timeout>
              <data/>
            </arguments>
          </parameters>
          <annotations>
            <_generic/>
            <_logging_behavior>
              <_exclude>false</_exclude>
              <_include>false</_include>
            </_logging_behavior>
            <_timing>
              <_timing_weight/>
              <_timing_avg/>
              <explanations/>
            </_timing>
            <_shifting>
              <_shifting_type>Duration</_shifting_type>
            </_shifting>
            <_context_data_analysis>
              <probes/>
              <ips/>
            </_context_data_analysis>
            <report>
              <url/>
            </report>
            <_notes>
              <_notes_general/>
            </_notes>
          </annotations>
          <documentation>
            <input/>
            <output/>
            <implementation>
              <description/>
            </implementation>
          </documentation>
        </call>
      </loop>
    </description>
  </description>
  <transformation>
    <description type="copy"/>
    <dataelements type="none"/>
    <endpoints type="none"/>
  </transformation>
</testset>